13:["$","$L14",null,{"formats":"$undefined","locale":"zh","messages":{"Metadata":{"title":"Gemini Turkiye | 尊享土耳其旅行体验","description":"精心策划的奢华之旅，穿越文明的十字路口。与Gemini Turkiye一起探索卡帕多奇亚、伊斯坦布尔、棉花堡及更多目的地。"},"Nav":{"home":"首页","about":"关于我们","destinations":"目的地","experiences":"体验","contact":"联系我们","bookNow":"立即预订"},"Hero":{"tagline":"东方与西方交汇之地","subtitle":"精心策划的奢华之旅，穿越文明的十字路口","cta":"规划您的旅程","scrollDown":"滚动探索"},"Destinations":{"sectionTitle":"标志性目的地","sectionSubtitle":"从古代遗迹到地中海海岸，探索土耳其最令人叹为观止的胜地","viewAll":"查看所有目的地","learnMore":"了解更多","cappadocia":{"name":"卡帕多奇亚","description":"在月球般的地貌上空，伴随日出体验精灵烟囱与热气球冒险"},"istanbul":{"name":"伊斯坦布尔","description":"大陆交汇之处——拜占庭的宏伟与奥斯曼的壮丽相遇"},"pamukkale":{"name":"棉花堡","description":"闪耀的白色石灰华梯田与古老的温泉池构成的棉花城堡"},"ephesus":{"name":"以弗所","description":"在保存最完好的古城之一中，漫步穿越数千年的历史"},"antalya":{"name":"安塔利亚","description":"地中海里维埃拉上，碧绿海岸线与古老的吕基亚遗迹交相辉映"},"gobeklitepe":{"name":"哥贝克力石阵","description":"世界上最古老的神庙群——改写人类文明的故事"},"bodrum":{"name":"博德鲁姆","description":"白墙村庄、蔚蓝海湾和传奇夜生活交织的爱琴海优雅"}},"Experiences":{"sectionTag":"体验","sectionTitle":"精选体验","sectionSubtitle":"以热情与专业打造的永恒记忆","balloon":{"name":"热气球之旅","description":"在日出时分翱翔于卡帕多奇亚的精灵烟囱之上，从空中见证超越想象的壮丽景观。","highlight":"卡帕多奇亚黎明飞行"},"gulet":{"name":"古帆船巡游","description":"乘坐传统土耳其木制古帆船，在爱琴海和地中海的碧绿水域中航行。","highlight":"沿海岸的私人游艇之旅"},"cultural":{"name":"文化之旅","description":"观赏令人着迷的旋转托钵僧仪式，探索跨越数个世纪的活态传统。","highlight":"塞马仪式与文化遗产之旅"},"food":{"name":"美食探险","description":"从伊斯坦布尔的香料集市到加济安泰普的厨房，品味土耳其料理丰富多彩的风味。","highlight":"正宗土耳其美食体验"},"exploreMore":"探索"},"Stats":{"years":"年经验","tours":"已完成行程","clients":"满意客户","destinations":"目的地"},"Testimonials":{"sectionTag":"客户评价","sectionTitle":"宾客故事","sectionSubtitle":"聆听与我们一起体验土耳其魅力的旅行者心声","items":[{"quote":"这是一次绝对改变人生的体验。黎明时分在卡帕多奇亚上空的热气球之旅是我一生中最神奇的时刻。","name":"Sarah Mitchell","location":"伦敦，英国","tour":"卡帕多奇亚探索之旅"},{"quote":"Gemini Turkiye打造了一段超越所有期望的旅程。对细节的关注无可挑剔。","name":"James Nakamura","location":"东京，日本","tour":"土耳其大环游"},{"quote":"从古帆船巡游到旋转托钵僧，每一刻都被精心策划到极致。真正令人难忘。","name":"Marie Dubois","location":"巴黎，法国","tour":"文化遗产之旅"},{"quote":"伊斯坦布尔的美食之旅令人大开眼界。我们发现了从未知晓的风味与传统。","name":"Marco Rossi","location":"米兰，意大利","tour":"美食发现之旅"}]},"CTA":{"tagline":"开启您的冒险之旅","title":"规划您的梦想之旅","subtitle":"让我们为您量身打造一段难忘的土耳其体验","button":"开始规划"},"About":{"heroTitle":"我们的故事","heroSubtitle":"自2010年以来，打造非凡的土耳其体验","storyTitle":"对土耳其的热忱","storyP1":"Gemini Turkiye诞生于对土耳其丰富文化、壮丽景观和悠久传统的深厚热爱。自2010年创立以来，我们致力于将这个非凡国度的真实之美分享给来自世界各地的品味旅行者。","storyP2":"我们的专业旅行设计团队将深入的本地知识与世界级的待客之道相结合，打造超越普通旅游的非凡旅程。每条行程都经过精心策划，在展示土耳其标志性地标的同时，揭示其隐藏的珍宝。","storyP3":"从卡帕多奇亚的精灵烟囱到爱琴海的碧蓝水域，从伊斯坦布尔热闹的集市到以弗所的古老遗迹——我们确保您土耳其之旅的每一刻都非同凡响。","valuesTitle":"我们的价值观","values":{"luxury":{"title":"至臻奢华","description":"每一个细节都经过精心策划，呈现最高水准的体验"},"authenticity":{"title":"文化真实性","description":"通过真正的本地体验，将您与土耳其的活态文化遗产相连"},"excellence":{"title":"卓越服务","description":"我们的专属团队确保从首次咨询到最终告别的无缝旅程"}}},"Contact":{"heroTitle":"联系我们","heroSubtitle":"从一次交谈开始您的土耳其之旅","formTitle":"给我们留言","form":{"name":"您的姓名","email":"电子邮箱","phone":"电话号码","interest":"感兴趣的行程","interests":{"select":"选择行程类型","cappadocia":"卡帕多奇亚探索","istanbul":"伊斯坦布尔发现","gulet":"古帆船巡游","cultural":"文化遗产","culinary":"美食探险","custom":"定制旅程"},"message":"您的留言","submit":"发送消息","sending":"发送中...","success":"消息发送成功！我们将尽快与您联系。","error":"出了点问题，请重试。"},"infoTitle":"联系信息","info":{"addressTitle":"地址","address":"Merkez mah. Halaskargazi cad.\nNo 175 Kat:8 Şişli – Istanbul Turkey","companyInfo":"Gemini Turizm Tic. A.S.\nŞişli VD. 3910312785","phoneTitle":"电话","phone":"+90 212 123 45 67","emailTitle":"邮箱","email":"info@geminiturkiye.com","hoursTitle":"营业时间","hours":"周一至周六：09:00 - 18:00"},"followTitle":"关注我们"},"DestinationsPage":{"heroTitle":"发现土耳其","heroSubtitle":"一片古老历史与壮美自然交融的土地","explore":"探索"},"ExperiencesPage":{"heroTitle":"非凡体验","heroSubtitle":"匠心打造的旅程，铸就一生的记忆","bookNow":"预订此体验"},"Footer":{"description":"横跨土耳其的精选奢华旅行体验。在专业本地导游的带领下，探索文明的十字路口。","quickLinks":"快速链接","company":"公司","contactUs":"联系我们","newsletter":"新闻通讯","newsletterText":"订阅获取独家旅行资讯与优惠","emailPlaceholder":"您的电子邮箱","subscribe":"订阅","rights":"保留所有权利。","privacy":"隐私政策","terms":"服务条款"}},"now":"$undefined","timeZone":"Europe/Istanbul","children":[["$","$L15",null,{}],["$","main",null,{"children":["$","$L2",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]}],"$L16"]}]
