f:["$","$L10",null,{"formats":"$undefined","locale":"ar","messages":{"Metadata":{"title":"Gemini Turkiye | تجارب سفر فاخرة إلى تركيا","description":"رحلات فاخرة منتقاة عبر ملتقى الحضارات. اكتشف كابادوكيا وإسطنبول وباموكالي والمزيد مع جيميني تركيا."},"Nav":{"home":"الرئيسية","about":"من نحن","destinations":"الوجهات","experiences":"التجارب","contact":"اتصل بنا","bookNow":"احجز الآن"},"Hero":{"tagline":"حيث يلتقي الشرق بالغرب","subtitle":"رحلات فاخرة منتقاة عبر ملتقى الحضارات","cta":"خطّط لرحلتك","scrollDown":"مرر للاستكشاف"},"Destinations":{"sectionTitle":"وجهات مميزة","sectionSubtitle":"من الآثار القديمة إلى شواطئ البحر المتوسط، اكتشف أكثر المواقع روعة في تركيا","viewAll":"عرض جميع الوجهات","learnMore":"اعرف المزيد","cappadocia":{"name":"كابادوكيا","description":"مداخن الجن ومغامرات المناطيد الهوائية عند شروق الشمس فوق مناظر طبيعية قمرية"},"istanbul":{"name":"إسطنبول","description":"حيث تتلاقى القارات — عظمة بيزنطية تلتقي بروعة عثمانية"},"pamukkale":{"name":"باموكالي","description":"مدرجات قلعة القطن من الترافرتين الأبيض المتلألئ وأحواض المياه الحرارية القديمة"},"ephesus":{"name":"أفسس","description":"امشِ عبر آلاف السنين من التاريخ في واحدة من أفضل المدن القديمة المحفوظة"},"antalya":{"name":"أنطاليا","description":"الساحل الفيروزي يلتقي بآثار ليقيا القديمة على ريفييرا البحر المتوسط"},"gobeklitepe":{"name":"غوبكلي تبه","description":"أقدم مجمع معابد في العالم — يعيد كتابة قصة الحضارة الإنسانية"},"bodrum":{"name":"بودروم","description":"أناقة بحر إيجه مع قرى بيضاء وخلجان زرقاء وحياة ليلية أسطورية"}},"Experiences":{"sectionTag":"تجارب","sectionTitle":"تجارب منتقاة","sectionSubtitle":"ذكريات خالدة صُنعت بشغف وخبرة","balloon":{"name":"رحلات المنطاد الهوائي","description":"حلّق فوق مداخن الجن في كابادوكيا عند شروق الشمس، وشاهد مناظر طبيعية تتحدى الخيال من السماء.","highlight":"رحلات الفجر فوق كابادوكيا"},"gulet":{"name":"رحلات الغوليت البحرية","description":"أبحر في المياه الفيروزية لبحر إيجه والبحر المتوسط على متن غوليت تركي خشبي تقليدي.","highlight":"يخت خاص على طول الساحل"},"cultural":{"name":"رحلات ثقافية","description":"شاهد حفل الدراويش الدوّارة الساحر واستكشف تقاليد حية تمتد عبر القرون.","highlight":"احتفالات السماع وجولات التراث"},"food":{"name":"مغامرات الطهي","description":"من سوق التوابل في إسطنبول إلى مطابخ غازي عنتاب، تذوّق النسيج الغني للمطبخ التركي.","highlight":"فن الطهي التركي الأصيل"},"exploreMore":"استكشف"},"Stats":{"years":"سنوات من الخبرة","tours":"جولات مكتملة","clients":"عملاء سعداء","destinations":"وجهات"},"Testimonials":{"sectionTag":"شهادات","sectionTitle":"قصص الضيوف","sectionSubtitle":"استمع إلى المسافرين الذين عاشوا سحر تركيا معنا","items":[{"quote":"تجربة تحويلية بكل ما تحمله الكلمة. كانت رحلة المنطاد فوق كابادوكيا عند الفجر أكثر اللحظات سحراً في حياتي.","name":"Sarah Mitchell","location":"لندن، المملكة المتحدة","tour":"مستكشف كابادوكيا"},{"quote":"صاغت جيميني تركيا رحلة فاقت كل التوقعات. كان الاهتمام بالتفاصيل لا تشوبه شائبة.","name":"James Nakamura","location":"طوكيو، اليابان","tour":"جولة تركيا الكبرى"},{"quote":"من رحلة الغوليت البحرية إلى الدراويش الدوّارة، كل لحظة كانت منسقة بإتقان. تجربة لا تُنسى حقاً.","name":"Marie Dubois","location":"باريس، فرنسا","tour":"رحلة التراث الثقافي"},{"quote":"كانت الجولة الغذائية في إسطنبول اكتشافاً مذهلاً. اكتشفنا نكهات وتقاليد لم نكن نعلم بوجودها.","name":"Marco Rossi","location":"ميلانو، إيطاليا","tour":"اكتشاف الطهي"}]},"CTA":{"tagline":"ابدأ مغامرتك","title":"خطّط لرحلة أحلامك","subtitle":"دعنا نصمم لك تجربة تركية لا تُنسى مصممة خصيصاً لك","button":"ابدأ التخطيط"},"About":{"heroTitle":"قصتنا","heroSubtitle":"نصنع تجارب تركية استثنائية منذ عام 2010","storyTitle":"شغف بتركيا","storyP1":"وُلدت جيميني تركيا من حب عميق للنسيج الغني من الثقافات والمناظر الطبيعية والتقاليد التركية. تأسست في عام 2010، وانطلقنا لمشاركة الجمال الأصيل لهذا البلد الاستثنائي مع المسافرين المميزين من جميع أنحاء العالم.","storyP2":"يجمع فريقنا من مصممي السفر الخبراء بين المعرفة المحلية العميقة والضيافة العالمية لإنشاء رحلات تتجاوز السياحة العادية. كل مسار رحلة مصمم بدقة لكشف جواهر تركيا المخفية إلى جانب معالمها الشهيرة.","storyP3":"من مداخن الجن في كابادوكيا إلى المياه الزرقاء لبحر إيجه، ومن أسواق إسطنبول الصاخبة إلى آثار أفسس القديمة — نضمن أن كل لحظة في رحلتك التركية لن تكون أقل من استثنائية.","valuesTitle":"قيمنا","values":{"luxury":{"title":"فخامة بلا حدود","description":"كل تفصيل منتقى بعناية لتقديم تجربة من أعلى مستوى"},"authenticity":{"title":"أصالة ثقافية","description":"نربطك بالتراث الحي لتركيا من خلال تجارب محلية أصيلة"},"excellence":{"title":"تميّز في الخدمة","description":"يضمن فريقنا المتفاني رحلات سلسة من الاستفسار الأول حتى الوداع الأخير"}}},"Contact":{"heroTitle":"تواصل معنا","heroSubtitle":"ابدأ رحلتك التركية بمحادثة","formTitle":"أرسل لنا رسالة","form":{"name":"اسمك","email":"البريد الإلكتروني","phone":"رقم الهاتف","interest":"الجولة المفضلة","interests":{"select":"اختر نوع الجولة","cappadocia":"مستكشف كابادوكيا","istanbul":"اكتشاف إسطنبول","gulet":"رحلة الغوليت البحرية","cultural":"التراث الثقافي","culinary":"مغامرة الطهي","custom":"رحلة مخصصة"},"message":"رسالتك","submit":"إرسال الرسالة","sending":"جارٍ الإرسال...","success":"تم إرسال الرسالة بنجاح! سنتواصل معك قريباً.","error":"حدث خطأ ما. يرجى المحاولة مرة أخرى."},"infoTitle":"معلومات الاتصال","info":{"addressTitle":"العنوان","address":"Merkez mah. Halaskargazi cad.\nNo 175 Kat:8 Şişli – Istanbul Turkey","companyInfo":"Gemini Turizm Tic. A.S.\nŞişli VD. 3910312785","phoneTitle":"الهاتف","phone":"+90 212 123 45 67","emailTitle":"البريد الإلكتروني","email":"info@geminiturkiye.com","hoursTitle":"ساعات العمل","hours":"الاثنين - السبت: 09:00 - 18:00"},"followTitle":"تابعنا"},"DestinationsPage":{"heroTitle":"اكتشف تركيا","heroSubtitle":"أرض حيث يلتقي التاريخ العريق بالجمال الطبيعي الخلاب","explore":"استكشف"},"ExperiencesPage":{"heroTitle":"تجارب استثنائية","heroSubtitle":"رحلات مصنوعة بعناية تخلق ذكريات تدوم مدى الحياة","bookNow":"احجز هذه التجربة"},"Footer":{"description":"تجارب سفر فاخرة منتقاة عبر تركيا. اكتشف ملتقى الحضارات مع مرشدين محليين خبراء.","quickLinks":"روابط سريعة","company":"الشركة","contactUs":"اتصل بنا","newsletter":"النشرة الإخبارية","newsletterText":"اشترك للحصول على معلومات سفر حصرية وعروض مميزة","emailPlaceholder":"بريدك الإلكتروني","subscribe":"اشترك","rights":"جميع الحقوق محفوظة.","privacy":"سياسة الخصوصية","terms":"شروط الخدمة"}},"now":"$undefined","timeZone":"Europe/Istanbul","children":["$L11","$L12","$L13"]}]
