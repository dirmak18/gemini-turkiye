{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/experiences/layout,_N_T_/[locale]/experiences/page,_N_T_/ar/experiences"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/experiences/__PAGE__",
    "/$d$locale/experiences",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}