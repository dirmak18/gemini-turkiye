f:["$","$L10",null,{"formats":"$undefined","locale":"tr","messages":{"Metadata":{"title":"Gemini Turkiye | Premium Türkiye Seyahat Deneyimleri","description":"Medeniyetlerin kavşağında özenle seçilmiş lüks yolculuklar. Gemini Turkiye ile Kapadokya, İstanbul, Pamukkale ve daha fazlasını keşfedin."},"Nav":{"home":"Ana Sayfa","about":"Hakkımızda","destinations":"Destinasyonlar","experiences":"Deneyimler","contact":"İletişim","bookNow":"Hemen Rezervasyon"},"Hero":{"tagline":"Doğu'nun Batı ile Buluştuğu Yer","subtitle":"Medeniyetlerin kavşağında özenle seçilmiş lüks yolculuklar","cta":"Yolculuğunuzu Planlayın","scrollDown":"Keşfetmek için kaydırın"},"Destinations":{"sectionTitle":"İkonik Destinasyonlar","sectionSubtitle":"Antik kalıntılardan Akdeniz kıyılarına, Türkiye'nin en nefes kesen yerlerini keşfedin","viewAll":"Tüm Destinasyonları Görüntüle","learnMore":"Daha Fazla Bilgi","cappadocia":{"name":"Kapadokya","description":"Ay manzarası üzerinde gün doğumunda peri bacaları ve sıcak hava balonu maceraları"},"istanbul":{"name":"İstanbul","description":"Kıtaların buluştuğu yer — Bizans ihtişamı Osmanlı görkemiyle buluşuyor"},"pamukkale":{"name":"Pamukkale","description":"Işıl ışıl beyaz travertenlerden oluşan pamuk kale terasları ve antik termal havuzlar"},"ephesus":{"name":"Efes","description":"En iyi korunmuş antik şehirlerden birinde binlerce yıllık tarihin içinde yürüyün"},"antalya":{"name":"Antalya","description":"Akdeniz riviyerasında turkuaz kıyı şeridi antik Likya kalıntılarıyla buluşuyor"},"gobeklitepe":{"name":"Göbeklitepe","description":"Dünyanın en eski tapınak kompleksi — insanlık medeniyetinin hikayesini yeniden yazıyor"},"bodrum":{"name":"Bodrum","description":"Beyaz badanalı köyler, masmavi koylar ve efsanevi gece hayatıyla Ege zarafeti"}},"Experiences":{"sectionTag":"Deneyimler","sectionTitle":"Özenle Seçilmiş Deneyimler","sectionSubtitle":"Tutku ve uzmanlıkla yaratılan zamansız anılar","balloon":{"name":"Sıcak Hava Balonu Turu","description":"Gün doğumunda Kapadokya'nın peri bacaları üzerinde süzülerek, hayal gücünü zorlayan bir manzarayı gökyüzünden izleyin.","highlight":"Kapadokya üzerinde şafak uçuşları"},"gulet":{"name":"Gulet Turları","description":"Geleneksel Türk ahşap guleti ile Ege ve Akdeniz'in turkuaz sularında yelken açın.","highlight":"Kıyı boyunca özel yat turu"},"cultural":{"name":"Kültürel Yolculuklar","description":"Büyüleyici Sema törenine tanık olun ve yüzyılları aşan yaşayan gelenekleri keşfedin.","highlight":"Sema törenleri ve miras turları"},"food":{"name":"Gastronomi Maceraları","description":"İstanbul'un baharat çarşısından Gaziantep mutfağına, Türk mutfağının zengin dokusunu tadın.","highlight":"Otantik Türk gastronomisi"},"exploreMore":"Keşfet"},"Stats":{"years":"Yıllık Deneyim","tours":"Tamamlanan Tur","clients":"Mutlu Misafir","destinations":"Destinasyon"},"Testimonials":{"sectionTag":"Misafir Yorumları","sectionTitle":"Misafir Hikayeleri","sectionSubtitle":"Bizimle Türkiye'nin büyüsünü yaşayan gezginlerin deneyimlerini dinleyin","items":[{"quote":"Kesinlikle dönüştürücü bir deneyimdi. Şafakta Kapadokya üzerindeki balon turu hayatımın en büyülü anıydı.","name":"Sarah Mitchell","location":"Londra, İngiltere","tour":"Kapadokya Kaşifi"},{"quote":"Gemini Turkiye her beklentimi aşan bir yolculuk tasarladı. Detaylara gösterilen özen kusursuzdu.","name":"James Nakamura","location":"Tokyo, Japonya","tour":"Büyük Türkiye Turu"},{"quote":"Gulet turundan Sema törenine kadar her an mükemmelliğe göre düzenlenmişti. Gerçekten unutulmaz.","name":"Marie Dubois","location":"Paris, Fransa","tour":"Kültürel Miras Yolculuğu"},{"quote":"İstanbul gastronomi turu bir keşif yolculuğuydu. Var olduğunu bilmediğimiz tatlar ve gelenekler keşfettik.","name":"Marco Rossi","location":"Milano, İtalya","tour":"Gastronomi Keşfi"}]},"CTA":{"tagline":"Maceranıza Başlayın","title":"Hayalinizdeki Yolculuğu Planlayın","subtitle":"Sadece sizin için tasarlanmış unutulmaz bir Türkiye deneyimi yaratmamıza izin verin","button":"Planlamaya Başlayın"},"About":{"heroTitle":"Hikayemiz","heroSubtitle":"2010'dan beri olağanüstü Türkiye deneyimleri yaratıyoruz","storyTitle":"Türkiye Tutkusu","storyP1":"Gemini Turkiye, Türkiye'nin zengin kültür, manzara ve gelenek dokusuna duyulan derin bir sevgiden doğdu. 2010 yılında kurulan şirketimiz, bu olağanüstü ülkenin otantik güzelliğini dünyanın dört bir yanından gelen seçkin gezginlerle paylaşmak amacıyla yola çıktı.","storyP2":"Uzman seyahat tasarımcılarından oluşan ekibimiz, sıradan turizmi aşan yolculuklar yaratmak için yakın yerel bilgiyi dünya standartlarında misafirperverlikle birleştiriyor. Her güzergah, Türkiye'nin gizli hazinelerini ikonik simgeleriyle birlikte ortaya çıkarmak için titizlikle hazırlanıyor.","storyP3":"Kapadokya'nın peri bacalarından Ege'nin masmavi sularına, İstanbul'un hareketli çarşılarından Efes'in antik kalıntılarına — Türkiye yolculuğunuzun her anının olağanüstü olmasını sağlıyoruz.","valuesTitle":"Değerlerimiz","values":{"luxury":{"title":"Ödünsüz Lüks","description":"Her detay en üst düzey bir deneyim sunmak için özenle seçilmiştir"},"authenticity":{"title":"Kültürel Özgünlük","description":"Sizi gerçek yerel deneyimler aracılığıyla Türkiye'nin yaşayan mirasıyla buluşturuyoruz"},"excellence":{"title":"Hizmet Mükemmelliği","description":"Özel ekibimiz ilk sorgulamadan son vedaya kadar kusursuz yolculuklar sağlar"}}},"Contact":{"heroTitle":"İletişime Geçin","heroSubtitle":"Türkiye yolculuğunuza bir sohbetle başlayın","formTitle":"Bize Mesaj Gönderin","form":{"name":"Adınız","email":"E-posta Adresi","phone":"Telefon Numarası","interest":"İlgilendiğiniz Tur","interests":{"select":"Bir tur türü seçin","cappadocia":"Kapadokya Kaşifi","istanbul":"İstanbul Keşfi","gulet":"Gulet Turu","cultural":"Kültürel Miras","culinary":"Gastronomi Macerası","custom":"Özel Yolculuk"},"message":"Mesajınız","submit":"Mesaj Gönder","sending":"Gönderiliyor...","success":"Mesajınız başarıyla gönderildi! En kısa sürede size dönüş yapacağız.","error":"Bir hata oluştu. Lütfen tekrar deneyin."},"infoTitle":"İletişim Bilgileri","info":{"addressTitle":"Adresimiz","address":"Merkez mah. Halaskargazi cad.\nNo 175 Kat:8 Şişli – Istanbul Turkey","companyInfo":"Gemini Turizm Tic. A.S.\nŞişli VD. 3910312785","phoneTitle":"Telefon","phone":"+90 212 123 45 67","emailTitle":"E-posta","email":"info@geminiturkiye.com","hoursTitle":"Çalışma Saatleri","hours":"Pzt - Cmt: 09:00 - 18:00"},"followTitle":"Bizi Takip Edin"},"DestinationsPage":{"heroTitle":"Türkiye'yi Keşfedin","heroSubtitle":"Kadim tarihin nefes kesen doğal güzellikle buluştuğu bir diyar","explore":"Keşfet"},"ExperiencesPage":{"heroTitle":"Olağanüstü Deneyimler","heroSubtitle":"Ömür boyu sürecek anılar yaratan el yapımı yolculuklar","bookNow":"Bu Deneyimi Rezerve Et"},"Footer":{"description":"Türkiye genelinde özenle seçilmiş lüks seyahat deneyimleri. Uzman yerel rehberlerle medeniyetlerin kavşağını keşfedin.","quickLinks":"Hızlı Bağlantılar","company":"Şirket","contactUs":"Bize Ulaşın","newsletter":"Bülten","newsletterText":"Özel seyahat bilgileri ve fırsatlar için abone olun","emailPlaceholder":"E-posta adresiniz","subscribe":"Abone Ol","rights":"Tüm hakları saklıdır.","privacy":"Gizlilik Politikası","terms":"Hizmet Şartları"}},"now":"$undefined","timeZone":"Europe/Istanbul","children":["$L11","$L12","$L13"]}]
