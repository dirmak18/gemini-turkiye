f:["$","$L10",null,{"formats":"$undefined","locale":"ja","messages":{"Metadata":{"title":"Gemini Turkiye | プレミアム・トルコ旅行体験","description":"文明の十字路を巡る厳選されたラグジュアリーな旅。Gemini Turkiyeでカッパドキア、イスタンブール、パムッカレなどを発見しましょう。"},"Nav":{"home":"ホーム","about":"私たちについて","destinations":"目的地","experiences":"体験","contact":"お問い合わせ","bookNow":"今すぐ予約"},"Hero":{"tagline":"東洋と西洋が出会う場所","subtitle":"文明の十字路を巡る厳選されたラグジュアリーな旅","cta":"旅を計画する","scrollDown":"スクロールして探索"},"Destinations":{"sectionTitle":"象徴的な目的地","sectionSubtitle":"古代遺跡から地中海の海岸まで、トルコで最も息をのむような場所を発見してください","viewAll":"すべての目的地を見る","learnMore":"詳しく見る","cappadocia":{"name":"カッパドキア","description":"月面のような風景の上で日の出とともに楽しむ妖精の煙突と熱気球の冒険"},"istanbul":{"name":"イスタンブール","description":"大陸が交わる場所 — ビザンチンの壮麗さとオスマンの威厳が出会う"},"pamukkale":{"name":"パムッカレ","description":"きらめく白い石灰華のテラスと古代の温泉プールが織りなす綿の城"},"ephesus":{"name":"エフェソス","description":"最も保存状態の良い古代都市のひとつで、数千年の歴史を歩く"},"antalya":{"name":"アンタルヤ","description":"地中海リビエラで古代リキアの遺跡とターコイズブルーの海岸線が出会う"},"gobeklitepe":{"name":"ギョベクリテペ","description":"世界最古の神殿複合体 — 人類文明の物語を書き換える"},"bodrum":{"name":"ボドルム","description":"白壁の村々、碧い入り江、伝説的なナイトライフが織りなすエーゲ海の優雅さ"}},"Experiences":{"sectionTag":"体験","sectionTitle":"厳選された体験","sectionSubtitle":"情熱と専門知識で創り出す永遠の思い出","balloon":{"name":"熱気球ライド","description":"日の出のカッパドキアで妖精の煙突の上を飛翔し、想像を超える風景を空から眺めましょう。","highlight":"カッパドキアでの夜明けフライト"},"gulet":{"name":"ギュレットクルーズ","description":"伝統的なトルコの木造帆船ギュレットに乗って、エーゲ海と地中海のターコイズブルーの海を航海しましょう。","highlight":"海岸沿いのプライベートヨット"},"cultural":{"name":"文化の旅","description":"魅惑的なメヴレヴィー旋舞教団の儀式を鑑賞し、何世紀にもわたる生きた伝統を探索しましょう。","highlight":"セマーの儀式と遺産ツアー"},"food":{"name":"グルメアドベンチャー","description":"イスタンブールのスパイスバザールからガズィアンテプの厨房まで、トルコ料理の豊かな織物を味わいましょう。","highlight":"本格的なトルコ料理の美食体験"},"exploreMore":"詳しく見る"},"Stats":{"years":"年の経験","tours":"完了したツアー","clients":"満足したお客様","destinations":"目的地"},"Testimonials":{"sectionTag":"お客様の声","sectionTitle":"ゲストストーリー","sectionSubtitle":"私たちとともにトルコの魔法を体験した旅行者の声をお聞きください","items":[{"quote":"まさに人生を変える体験でした。夜明けのカッパドキアでの気球飛行は、人生で最も魔法のような瞬間でした。","name":"Sarah Mitchell","location":"ロンドン、イギリス","tour":"カッパドキア エクスプローラー"},{"quote":"Gemini Turkiyeは、あらゆる期待を超える旅を創り上げてくれました。細部へのこだわりは完璧でした。","name":"James Nakamura","location":"東京、日本","tour":"グランド トルコ ツアー"},{"quote":"ギュレットクルーズから旋舞教団まで、すべての瞬間が完璧にキュレーションされていました。本当に忘れられない体験です。","name":"Marie Dubois","location":"パリ、フランス","tour":"文化遺産の旅"},{"quote":"イスタンブールのグルメツアーは衝撃的でした。存在すら知らなかった味と伝統を発見しました。","name":"Marco Rossi","location":"ミラノ、イタリア","tour":"グルメディスカバリー"}]},"CTA":{"tagline":"冒険を始めましょう","title":"夢の旅を計画しましょう","subtitle":"あなただけのために特別にデザインされた忘れられないトルコ体験を創り上げます","button":"計画を始める"},"About":{"heroTitle":"私たちの物語","heroSubtitle":"2010年から特別なトルコ体験を創り続けています","storyTitle":"トルコへの情熱","storyP1":"Gemini Turkiyeは、トルコの豊かな文化、風景、伝統への深い愛情から生まれました。2010年に設立され、この素晴らしい国の本物の美しさを世界中の目の肥えた旅行者と共有することを目指してきました。","storyP2":"私たちの専門トラベルデザイナーチームは、親密な現地知識と世界クラスのホスピタリティを組み合わせ、通常の観光を超える旅を創り出します。すべての旅程は、トルコの隠れた宝石と象徴的なランドマークの両方を明らかにするために、細心の注意を払って作成されます。","storyP3":"カッパドキアの妖精の煙突からエーゲ海の碧い海まで、イスタンブールの活気あるバザールからエフェソスの古代遺跡まで — トルコの旅のすべての瞬間が特別なものになることをお約束します。","valuesTitle":"私たちの価値観","values":{"luxury":{"title":"妥協なきラグジュアリー","description":"すべての細部が最高水準の体験を提供するためにキュレーションされています"},"authenticity":{"title":"文化的な真正性","description":"本物の現地体験を通じて、トルコの生きた遺産とお客様をつなぎます"},"excellence":{"title":"サービスの卓越性","description":"専任チームが最初のお問い合わせから最後のお別れまで、シームレスな旅をお約束します"}}},"Contact":{"heroTitle":"お問い合わせ","heroSubtitle":"会話からトルコの旅を始めましょう","formTitle":"メッセージを送る","form":{"name":"お名前","email":"メールアドレス","phone":"電話番号","interest":"ご興味のあるツアー","interests":{"select":"ツアータイプを選択","cappadocia":"カッパドキア エクスプローラー","istanbul":"イスタンブール ディスカバリー","gulet":"ギュレットクルーズ","cultural":"文化遺産","culinary":"グルメアドベンチャー","custom":"カスタムジャーニー"},"message":"メッセージ","submit":"メッセージを送信","sending":"送信中...","success":"メッセージが正常に送信されました！まもなくご連絡いたします。","error":"問題が発生しました。もう一度お試しください。"},"infoTitle":"連絡先情報","info":{"addressTitle":"住所","address":"Merkez mah. Halaskargazi cad.\nNo 175 Kat:8 Şişli – Istanbul Turkey","companyInfo":"Gemini Turizm Tic. A.S.\nŞişli VD. 3910312785","phoneTitle":"電話","phone":"+90 212 123 45 67","emailTitle":"メール","email":"info@geminiturkiye.com","hoursTitle":"営業時間","hours":"月〜土：09:00 - 18:00"},"followTitle":"フォローする"},"DestinationsPage":{"heroTitle":"トルコを発見する","heroSubtitle":"古代の歴史と息をのむ自然の美しさが出会う土地","explore":"探索する"},"ExperiencesPage":{"heroTitle":"特別な体験","heroSubtitle":"一生の思い出を創る手作りの旅","bookNow":"この体験を予約する"},"Footer":{"description":"トルコ全土にわたる厳選されたラグジュアリー旅行体験。専門の現地ガイドとともに文明の十字路を発見しましょう。","quickLinks":"クイックリンク","company":"会社情報","contactUs":"お問い合わせ","newsletter":"ニュースレター","newsletterText":"限定の旅行情報やオファーを購読する","emailPlaceholder":"メールアドレス","subscribe":"購読する","rights":"全著作権所有。","privacy":"プライバシーポリシー","terms":"利用規約"}},"now":"$undefined","timeZone":"Europe/Istanbul","children":["$L11","$L12","$L13"]}]
