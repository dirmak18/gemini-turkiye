f:["$","$L10",null,{"formats":"$undefined","locale":"it","messages":{"Metadata":{"title":"Gemini Turkiye | Esperienze di Viaggio Premium in Turchia","description":"Viaggi di lusso selezionati attraverso il crocevia delle civiltà. Scopri la Cappadocia, Istanbul, Pamukkale e molto altro con Gemini Turkiye."},"Nav":{"home":"Home","about":"Chi Siamo","destinations":"Destinazioni","experiences":"Esperienze","contact":"Contatti","bookNow":"Prenota Ora"},"Hero":{"tagline":"Dove l'Oriente Incontra l'Occidente","subtitle":"Viaggi di lusso selezionati attraverso il crocevia delle civiltà","cta":"Pianifica il Tuo Viaggio","scrollDown":"Scorri per esplorare"},"Destinations":{"sectionTitle":"Destinazioni Iconiche","sectionSubtitle":"Dalle rovine antiche alle coste mediterranee, scopri i luoghi più mozzafiato della Turchia","viewAll":"Vedi Tutte le Destinazioni","learnMore":"Scopri di Più","cappadocia":{"name":"Cappadocia","description":"Camini delle fate e avventure in mongolfiera all'alba su un paesaggio lunare"},"istanbul":{"name":"Istanbul","description":"Dove i continenti si incontrano — la grandezza bizantina incontra la magnificenza ottomana"},"pamukkale":{"name":"Pamukkale","description":"Terrazze di castello di cotone con travertini bianchi scintillanti e antiche piscine termali"},"ephesus":{"name":"Efeso","description":"Cammina attraverso millenni di storia in una delle città antiche meglio conservate"},"antalya":{"name":"Antalya","description":"La costa turchese incontra le antiche rovine licie sulla riviera mediterranea"},"gobeklitepe":{"name":"Göbeklitepe","description":"Il più antico complesso di templi al mondo — riscrivendo la storia della civiltà umana"},"bodrum":{"name":"Bodrum","description":"Eleganza egea con villaggi imbiancati a calce, baie azzurre e vita notturna leggendaria"}},"Experiences":{"sectionTag":"Esperienze","sectionTitle":"Esperienze Selezionate","sectionSubtitle":"Ricordi senza tempo creati con passione e competenza","balloon":{"name":"Voli in Mongolfiera","description":"Sorvola i camini delle fate della Cappadocia all'alba, ammirando dal cielo un paesaggio che sfida l'immaginazione.","highlight":"Voli all'alba sulla Cappadocia"},"gulet":{"name":"Crociere in Caicco","description":"Naviga sulle acque turchesi dell'Egeo e del Mediterraneo a bordo di un tradizionale caicco turco in legno.","highlight":"Yacht privato lungo la costa"},"cultural":{"name":"Viaggi Culturali","description":"Assisti all'affascinante cerimonia dei Dervisci Rotanti ed esplora tradizioni viventi che attraversano i secoli.","highlight":"Cerimonie Sema e tour del patrimonio"},"food":{"name":"Avventure Culinarie","description":"Dal bazar delle spezie di Istanbul alle cucine di Gaziantep, assapora il ricco arazzo della cucina turca.","highlight":"Gastronomia turca autentica"},"exploreMore":"Scopri"},"Stats":{"years":"Anni di Esperienza","tours":"Tour Completati","clients":"Clienti Soddisfatti","destinations":"Destinazioni"},"Testimonials":{"sectionTag":"Testimonianze","sectionTitle":"Storie degli Ospiti","sectionSubtitle":"Ascolta i viaggiatori che hanno vissuto la magia della Turchia con noi","items":[{"quote":"Un'esperienza assolutamente trasformativa. Il volo in mongolfiera sulla Cappadocia all'alba è stato il momento più magico della mia vita.","name":"Sarah Mitchell","location":"Londra, Regno Unito","tour":"Esploratore della Cappadocia"},{"quote":"Gemini Turkiye ha creato un viaggio che ha superato ogni aspettativa. L'attenzione ai dettagli è stata impeccabile.","name":"James Nakamura","location":"Tokyo, Giappone","tour":"Gran Tour della Turchia"},{"quote":"Dalla crociera in caicco ai Dervisci Rotanti, ogni momento è stato curato alla perfezione. Davvero indimenticabile.","name":"Marie Dubois","location":"Parigi, Francia","tour":"Viaggio nel Patrimonio Culturale"},{"quote":"Il tour culinario di Istanbul è stato una rivelazione. Abbiamo scoperto sapori e tradizioni di cui non conoscevamo l'esistenza.","name":"Marco Rossi","location":"Milano, Italia","tour":"Scoperta Culinaria"}]},"CTA":{"tagline":"Inizia La Tua Avventura","title":"Pianifica il Viaggio dei Tuoi Sogni","subtitle":"Lascia che creiamo un'esperienza turca indimenticabile su misura per te","button":"Inizia a Pianificare"},"About":{"heroTitle":"La Nostra Storia","heroSubtitle":"Creiamo esperienze turche straordinarie dal 2010","storyTitle":"Una Passione per la Turchia","storyP1":"Gemini Turkiye è nato da un profondo amore per il ricco mosaico di culture, paesaggi e tradizioni della Turchia. Fondato nel 2010, ci siamo proposti di condividere l'autentica bellezza di questo straordinario Paese con viaggiatori esigenti di tutto il mondo.","storyP2":"Il nostro team di esperti designer di viaggio unisce un'intima conoscenza locale con un'ospitalità di classe mondiale per creare viaggi che trascendono il turismo ordinario. Ogni itinerario è meticolosamente progettato per rivelare i tesori nascosti della Turchia accanto ai suoi monumenti iconici.","storyP3":"Dai camini delle fate della Cappadocia alle acque azzurre dell'Egeo, dai vivaci bazar di Istanbul alle antiche rovine di Efeso — ci assicuriamo che ogni momento del vostro viaggio in Turchia sia straordinario.","valuesTitle":"I Nostri Valori","values":{"luxury":{"title":"Lusso Senza Compromessi","description":"Ogni dettaglio è curato per offrire un'esperienza del massimo livello"},"authenticity":{"title":"Autenticità Culturale","description":"Vi connettiamo con il patrimonio vivente della Turchia attraverso esperienze locali autentiche"},"excellence":{"title":"Eccellenza nel Servizio","description":"Il nostro team dedicato garantisce viaggi impeccabili dalla prima richiesta fino all'ultimo arrivederci"}}},"Contact":{"heroTitle":"Contattaci","heroSubtitle":"Inizia il tuo viaggio in Turchia con una conversazione","formTitle":"Inviaci un Messaggio","form":{"name":"Il Tuo Nome","email":"Indirizzo E-mail","phone":"Numero di Telefono","interest":"Tour di Interesse","interests":{"select":"Seleziona un tipo di tour","cappadocia":"Esploratore della Cappadocia","istanbul":"Scoperta di Istanbul","gulet":"Crociera in Caicco","cultural":"Patrimonio Culturale","culinary":"Avventura Culinaria","custom":"Viaggio Su Misura"},"message":"Il Tuo Messaggio","submit":"Invia Messaggio","sending":"Invio in corso...","success":"Messaggio inviato con successo! Ti risponderemo presto.","error":"Qualcosa è andato storto. Per favore riprova."},"infoTitle":"Informazioni di Contatto","info":{"addressTitle":"Indirizzo","address":"Merkez mah. Halaskargazi cad.\nNo 175 Kat:8 Şişli – Istanbul Turkey","companyInfo":"Gemini Turizm Tic. A.S.\nŞişli VD. 3910312785","phoneTitle":"Telefono","phone":"+90 212 123 45 67","emailTitle":"Email","email":"info@geminiturkiye.com","hoursTitle":"Orari","hours":"Lun - Sab: 09:00 - 18:00"},"followTitle":"Seguici"},"DestinationsPage":{"heroTitle":"Scopri la Turchia","heroSubtitle":"Una terra dove la storia antica incontra una bellezza naturale mozzafiato","explore":"Esplora"},"ExperiencesPage":{"heroTitle":"Esperienze Straordinarie","heroSubtitle":"Viaggi artigianali che creano ricordi per tutta la vita","bookNow":"Prenota Questa Esperienza"},"Footer":{"description":"Esperienze di viaggio di lusso selezionate in tutta la Turchia. Scopri il crocevia delle civiltà con guide locali esperte.","quickLinks":"Link Rapidi","company":"Azienda","contactUs":"Contattaci","newsletter":"Newsletter","newsletterText":"Iscriviti per approfondimenti di viaggio esclusivi e offerte","emailPlaceholder":"Il tuo indirizzo e-mail","subscribe":"Iscriviti","rights":"Tutti i diritti riservati.","privacy":"Informativa sulla Privacy","terms":"Termini di Servizio"}},"now":"$undefined","timeZone":"Europe/Istanbul","children":["$L11","$L12","$L13"]}]
